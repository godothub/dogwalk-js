; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

warnings/check_invalid_track_paths=false
compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="DOGWALK"
config/description="Play as a big adorable dog and explore a hand-crafted winter forest with a little kid in tow.
A short, free, open source project brought to you by Blender Studio."
config/version="v1.0.1"
run/main_scene="uid://d3i1jbwaf8wjo"
config/project_settings_override="user://project_overrides.cfg"
config/features=PackedStringArray("4.6", "Forward Plus")
run/max_fps=60
boot_splash/show_image=false
boot_splash/stretch_mode=0
boot_splash/use_filter=false
config/icon="uid://ch3u8f3yk05k2"

[audio]

driver/output_latency=25

[autoload]

Assignment="*res://source/globals/assignment.gd"
InputController="*res://source/globals/input_controller.gd"
Constants="*res://source/globals/constants.gd"
Context="*res://source/globals/context.gd"
SignalBus="*res://source/globals/signal_bus.gd"
Settings="*res://source/globals/settings.gd"
GameStatus="*res://source/globals/game_status.gd"
SaveManager="*res://source/globals/save_manager.gd"
ToppleManager="*res://source/globals/topple_manager.gd"
WiggleManager="*res://source/globals/wiggle_manager.gd"
Launch="*res://source/globals/launch.gd"

[debug]

shapes/collision/shape_color=Color(0, 0.6, 0.701961, 0.862745)

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/mode=3
window/size/initial_position_type=3
window/stretch/mode="viewport"
window/stretch/aspect="expand"
mouse_cursor/custom_image="uid://kcwun8id06o2"
mouse_cursor/custom_image_hotspot=Vector2(12.5, 5)

[editor_plugins]

enabled=PackedStringArray("res://addons/blender_studio_gltf_import/plugin.cfg", "res://addons/lines_and_trails_3d/plugin.cfg")

[global_group]

LeashPivots=""
Player=""
TerrainIce=""
TerrainSnow=""
Snowman=""
Persist="Add to save handling"
TrippingHazard=""

[importer_defaults]

animation_library={
&"import_script/path": "uid://c3ckqnprn4mt"
}
scene={
&"import_script/path": "uid://gtfffogvk6gb"
}

